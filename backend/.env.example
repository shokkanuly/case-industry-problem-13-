# Edge Telemetry Backend — Environment Variables
# Copy this file to .env and fill in your values

EDGE_API_KEY=your-secret-api-key-here
SQLITE_PATH=telemetry.db
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
WS_BROADCAST_INTERVAL_MS=500
ALERT_POWER_THRESHOLD_W=3000
ALERT_BATTERY_LOW_V=2.8
ALERT_TEMP_HIGH_C=35.0
DEVICE_OFFLINE_TIMEOUT_S=30
